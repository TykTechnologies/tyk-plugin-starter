{
  "name": "auth-check-e2e",
  "api_id": "auth-check-e2e",
  "org_id": "default",
  "use_keyless": false,
  "active": true,
  "enable_coprocess_auth": true,
  "auth": { "auth_header_name": "Authorization" },
  "definition": {
    "location": "header",
    "key": "x-api-version"
  },
  "version_data": {
    "not_versioned": true,
    "versions": {
      "Default": {
        "name": "Default",
        "use_extended_paths": true
      }
    }
  },
  "config_data": {
    "hmac_secret": "e2e-hmac-secret-1234"
  },
  "custom_middleware_bundle": "auth-check-hmac.zip",
  "custom_middleware_bundle_disabled": false,
  "proxy": {
    "listen_path": "/auth/",
    "target_url": "http://httpbin.org/",
    "strip_listen_path": true
  }
}
