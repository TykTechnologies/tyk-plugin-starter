{
  "name": "multi-bundle-demo",
  "api_id": "multi-bundle-demo",
  "org_id": "default",
  "use_keyless": true,
  "active": true,
  "definition": {
    "location": "header",
    "key": "x-api-version"
  },
  "version_data": {
    "not_versioned": true,
    "versions": {
      "Default": {
        "name": "Default",
        "use_extended_paths": true
      }
    }
  },
  "config_data": {
    "jws_secret": "demo-shared-secret"
  },
  "custom_middleware_bundle": "pre-trace-id.zip,jws-request-signing.zip",
  "custom_middleware_bundle_disabled": false,
  "proxy": {
    "listen_path": "/multi/",
    "target_url": "http://httpbin.org/",
    "strip_listen_path": true
  }
}
