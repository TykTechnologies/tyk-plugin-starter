{
  "name": "tyk-plugin-starter",
  "version": "0.1.0",
  "description": "Starter project for Tyk goja plugins — author, test, and build locally; deploy to a Tyk gateway when ready.",
  "private": true,
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "webpack --mode production",
    "build:bundle": "npm run build && node scripts/build-bundle.mjs",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "buffer": "^6.0.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  }
}
